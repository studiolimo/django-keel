# docker-compose.prod.yml
# Deploy produzione — branch: production
# Avvio: docker compose -f docker-compose.prod.yml up -d

name: {{ project_slug }}_prod

# DATABASE_URL derivata dai POSTGRES_* — unica fonte di verità per la password
x-app-env: &app-env
  DATABASE_URL: postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

services:
  frontend:
    image: ghcr.io/{{ git_repository_org_name }}/{{ git_repository_project_slug }}:latest
    restart: unless-stopped
    networks:
      - traefik_public
    labels:
      - "traefik.enable=true"
      # Router principale: www.{{ project_domain_url }}
      - "traefik.http.routers.frontend-{{ project_slug }}-prod.rule=Host(`www.{{ project_domain_url }}`)"
      - "traefik.http.routers.frontend-{{ project_slug }}-prod.entrypoints=websecure"
      - "traefik.http.routers.frontend-{{ project_slug }}-prod.tls.certresolver=letsencrypt"
      - "traefik.http.services.frontend-{{ project_slug }}-prod.loadbalancer.server.port=80"
      # Router apex: {{ project_domain_url }} → redirect permanente a www.{{ project_domain_url }}
      - "traefik.http.routers.frontend-{{ project_slug }}-prod-apex.rule=Host(`{{ project_domain_url }}`)"
      - "traefik.http.routers.frontend-{{ project_slug }}-prod-apex.entrypoints=websecure"
      - "traefik.http.routers.frontend-{{ project_slug }}-prod-apex.tls.certresolver=letsencrypt"
      - "traefik.http.routers.frontend-{{ project_slug }}-prod-apex.middlewares=redirect-apex-to-www@docker"
      - "traefik.http.routers.frontend-{{ project_slug }}-prod-apex.service=frontend-{{ project_slug }}-prod"
      - "traefik.http.middlewares.redirect-apex-to-www.redirectregex.regex=^https://{{ project_domain_url | replace(".", "\\.") }}/(.*)"
      - "traefik.http.middlewares.redirect-apex-to-www.redirectregex.replacement=https://www.{{ project_domain_url }}/$${1}"
      - "traefik.http.middlewares.redirect-apex-to-www.redirectregex.permanent=true"

  backend:
    image: ghcr.io/{{ git_repository_org_name }}/{{ git_repository_project_slug }}:latest
    restart: unless-stopped
    env_file: .env.prod
    environment: *app-env
    volumes:
      - media_prod:/app/media
    networks:
      - traefik_public
      - internal_prod
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.backend-{{ project_slug }}-prod.rule=Host(`be.{{ project_domain_url }}`)"
      - "traefik.http.routers.backend-{{ project_slug }}-prod.entrypoints=websecure"
      - "traefik.http.routers.backend-{{ project_slug }}-prod.tls.certresolver=letsencrypt"
      - "traefik.http.services.backend-{{ project_slug }}-prod.loadbalancer.server.port=8000"
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy

  nginx-media:
    image: nginx:alpine
    restart: unless-stopped
    volumes:
      - media_prod:/app/media:ro
      - ./nginx/nginx-media.conf:/etc/nginx/conf.d/default.conf:ro
    networks:
      - traefik_public
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.media-{{ project_slug }}-prod.rule=Host(`be.{{ project_domain_url }}`) && PathPrefix(`/media/`)"
      - "traefik.http.routers.media-{{ project_slug }}-prod.entrypoints=websecure"
      - "traefik.http.routers.media-{{ project_slug }}-prod.tls.certresolver=letsencrypt"
      - "traefik.http.services.media-{{ project_slug }}-prod.loadbalancer.server.port=80"

  celery:
    image: ghcr.io/{{ git_repository_org_name }}/{{ git_repository_project_slug }}:latest
    restart: unless-stopped
    command: uv run celery -A config worker -l info --concurrency=2
    env_file: .env.prod
    environment: *app-env
    networks:
      - internal_prod
    depends_on:
      - backend

  celerybeat:
    image: ghcr.io/{{ git_repository_org_name }}/{{ git_repository_project_slug }}:latest
    restart: unless-stopped
    command: uv run celery -A config beat -l info --scheduler django_celery_beat.schedulers:DatabaseScheduler
    env_file: .env.prod
    environment: *app-env
    networks:
      - internal_prod
    depends_on:
      - backend

  postgres:
    image: postgres:16-alpine
    restart: unless-stopped
    env_file: .env.prod
    volumes:
      - postgres_prod:/var/lib/postgresql/data
    networks:
      - internal_prod
    healthcheck:
      test: [ "CMD-SHELL", "pg_isready -U $$POSTGRES_USER -d $$POSTGRES_DB" ]
      interval: 10s
      timeout: 5s
      retries: 5

  redis:
    image: redis:7-alpine
    restart: unless-stopped
    volumes:
      - redis_prod:/data
    networks:
      - internal_prod
    healthcheck:
      test: [ "CMD", "redis-cli", "ping" ]
      interval: 10s
      timeout: 5s
      retries: 5

volumes:
  postgres_prod:
  redis_prod:
  media_prod:

networks:
  traefik_public:
    external: true
  internal_prod:
