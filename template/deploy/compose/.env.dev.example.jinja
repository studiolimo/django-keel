# Django
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_SECRET_KEY=dev-secret-key-change-me
DEBUG=false
DJANGO_ALLOWED_HOSTS=.{{ project_domain_url }}

# Site
SITE_NAME={{ project_name }} Dev
SITE_URL=https://be-dev.{{ project_domain_url }}
FRONTEND_URL=https://dev.{{ project_domain_url }}

# Database
POSTGRES_DB={{ project_slug }}_dev
POSTGRES_USER={{ project_slug }}_dev
POSTGRES_PASSWORD=change-me-dev
# DATABASE_URL è derivata dai POSTGRES_* nel docker-compose — non metterla qui

# Redis & Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

# CORS & CSRF
CORS_ALLOWED_ORIGINS=https://dev.{{ project_domain_url }},capacitor://localhost,http://localhost
CSRF_TRUSTED_ORIGINS=https://dev.{{ project_domain_url }},https://be-dev.{{ project_domain_url }}

# Email (Brevo)
DJANGO_EMAIL_BACKEND=anymail.backends.brevo.EmailBackend
BREVO_API_KEY=
DEFAULT_FROM_EMAIL=noreply@{{ project_domain_url }}
SUPPORT_EMAIL=support@{{ project_domain_url }}

# Social Auth
GOOGLE_OAUTH_CLIENT_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# Bundle ID dell'app iOS (default già impostato)
APPLE_BUNDLE_ID=
# Services ID per il web (da impostare)
APPLE_SERVICES_ID=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_WEBHOOK_SECRET=

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Logging
DJANGO_LOG_LEVEL=DEBUG
