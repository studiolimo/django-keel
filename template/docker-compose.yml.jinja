services:
  db:
    image: postgres:16-alpine
    environment:
      POSTGRES_DB: {{ project_slug }}_db
      POSTGRES_USER: {{ project_slug }}_user
      POSTGRES_PASSWORD: {{ project_slug }}_password
    volumes:
      - postgres_data:/var/lib/postgresql/data
    ports:
      - "8432:5432"
    env_file:
      - .env

  redis:
    image: redis:7-alpine
    ports:
      - "6379:6379"
    volumes:
      - redis_data:/data
    healthcheck:
      test: [ "CMD", "redis-cli", "ping" ]
      interval: 10s
      timeout: 5s
      retries: 5

  mailpit:
    image: axllent/mailpit:latest
    ports:
      - "1025:1025"
      - "8025:8025"

  stripe:
    image: stripe/stripe-cli:v1.35.1
    environment:
      - STRIPE_API_KEY=${STRIPE_SECRET_KEY}
    env_file:
      - .env
    command: [ "listen", "--forward-to", "http://host.docker.internal:8000/webhooks/stripe/" ]


volumes:
  postgres_data:
  redis_data:
