[project]
name = "{{ project_slug }}_backend"
version = "0.1.0"
description = "Backend for {{ project_name }} App"

authors = [
    { name = "{{ author_name }}", email = "{{ author_email }}" }
]

readme = "README.md"
requires-python = ">=3.14"
license = { text = "Proprietary" }

dependencies = [
    "django>=5.2,<5.3",
    "django-environ>=0.11.2",
    "psycopg[binary]>=3.2.0",
    "redis>=5.0.0",
    "django-redis>=5.4.0",
    "gunicorn>=22.0.0",
    "whitenoise[brotli]>=6.6.0",
    "python-json-logger>=2.0.7",
    "djangorestframework>=3.15.0",
    "drf-spectacular>=0.27.0",
    "django-filter>=24.0",
    "django-cors-headers>=4.3.0",
    "djangorestframework-simplejwt>=5.3.0",
    "celery[redis]>=5.4.0",
    "django-celery-beat>=2.8.0", # 2.8+ required for Django 5.2 + OpenTelemetry compatibility
    "django-celery-results>=2.5.0",
    "flower>=2.0.0",
    "sentry-sdk[django]>=2.0.0",
    "django-waffle>=4.1.0",
    "django-postgres-extra>=2.0.0",
    "django-modeltranslation>=0.7.3",
    "django-extensions>=3.2.0",
    "python-dotenv>=1.0.0",
    "django-alive>=1.3.0",
    "django-role-permissions>=3.2.0",
    "pillow-heif>=1.1.1", # little outdated but can avoid some tricky local build issues
    "stripe>=14.3.0",
    "django-anymail[brevo]>=13.2.0",
    "google-auth>=2.48.0",
    "requests>=2.32.5",
    "django-phonenumber-field>=8.0.0",
    "phonenumbers>=8.13.0",
    "django-unfold>=0.83.1",
    "django-crispy-forms>=2.6",
    "crispy-tailwind>=1.0.3",
    "django-addanother>=2.2.2",
    "django-dirtyfields>=1.9.9",
    "django-extra-views>=0.16.0",
    "django-tables2>=3.0.0",
    "python-slugify>=8.0.4",
    "tablib[xlsx]>=3.9.0",
]

[dependency-groups]
dev = [
    # Testing
    "pytest>=8.0.0",
    "pytest-django>=4.8.0",
    "pytest-cov>=5.0.0",
    "pytest-xdist>=3.5.0",
    "faker>=24.0.0",
    "model-bakery>=1.17.0",
    "hypothesis>=6.100.0",
    # Code Quality
    "ruff>=0.4.0",
    "mypy>=1.10.0",
    "django-stubs[compatible-mypy]>=5.0.0",
    "djangorestframework-stubs[compatible-mypy]>=3.15.0",
    # Tools
    "django-debug-toolbar>=4.3.0",
    "ipython>=8.23.0",
    "pre-commit>=3.7.0",
    # Security
    "pip-audit>=2.7.0",
    "safety>=3.1.0",
    # Docs
    "mkdocs>=1.5.0",
    "mkdocs-material>=9.5.0",
    "mkdocstrings[python]>=0.24.0",
    "freezegun>=1.5.5",
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["apps", "config"]

[tool.ruff]
line-length = 100
target-version = "py314"

[tool.ruff.lint]
select = [
    "E", # pycodestyle errors
    "W", # pycodestyle warnings
    "F", # pyflakes
    "I", # isort
    "B", # flake8-bugbear
    "C4", # flake8-comprehensions
    "UP", # pyupgrade
    "ARG", # flake8-unused-arguments
    "SIM", # flake8-simplify
    "DJ", # flake8-django
]
ignore = [
    "E501", # line too long (handled by formatter)
    "B008", # do not perform function calls in argument defaults
    "DJ001", # avoid using null=True on string-based fields
]

[tool.ruff.lint.per-file-ignores]
"__init__.py" = ["F401"]  # unused imports
"*/migrations/*" = ["E501", "DJ", "ARG"]  # ignore in migrations
"tests/**" = ["ARG", "S", "SIM117"]  # ignore in tests (root tests/ dir)
"*/tests/**" = ["ARG", "S", "SIM117"]  # ignore in tests (app-level tests/)
"config/settings/*.py" = ["F405", "F403"]  # allow star imports in settings

[tool.ruff.lint.isort]
known-first-party = ["elio_backend", "apps", "config"]
section-order = [
    "future",
    "standard-library",
    "third-party",
    "first-party",
    "local-folder",
]

[tool.mypy]
python_version = "3.14"
check_untyped_defs = true
ignore_missing_imports = false
warn_unused_ignores = false
warn_redundant_casts = true
warn_unused_configs = true
disable_error_code = ["import-untyped"]
plugins = ["mypy_django_plugin.main", "mypy_drf_plugin.main"]

[[tool.mypy.overrides]]
module = "*.migrations.*"
ignore_errors = true

[[tool.mypy.overrides]]
module = "tests.*"
ignore_errors = true

[[tool.mypy.overrides]]
module = "phonenumber_field.*"
ignore_missing_imports = true

[[tool.mypy.overrides]]
module = [
    "celery.*",
    "environ.*",
    "rolepermissions.*",
    "django_filters.*",
    "debug_toolbar.*",
]
ignore_missing_imports = true

[tool.django-stubs]
django_settings_module = "config.settings.local"

[tool.coverage.run]
source = ["elio_backend"]
omit = [
    "*/migrations/*",
    "*/tests/*",
    "*/__pycache__/*",
    "*/venv/*",
    "*/.venv/*",
]

[tool.coverage.report]
exclude_lines = [
    "pragma: no cover",
    "def __repr__",
    "raise AssertionError",
    "raise NotImplementedError",
    "if __name__ == .__main__.:",
    "if TYPE_CHECKING:",
    "@abstractmethod",
]
