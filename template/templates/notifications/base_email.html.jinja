<!DOCTYPE html>
<html lang="it" xmlns:v="urn:schemas-microsoft-com:vml">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="x-apple-disable-message-reformatting">
    <title>{% raw %}{% block title %}{% endraw %}{{ project_name }}{% raw %}{% endblock %}{% endraw %}</title>
    <!--[if !mso]><!-->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
          rel="stylesheet">
    <!--<![endif]-->
    <style>
        body {
            margin: 0;
            padding: 0;
            background-color: #F4F4F0;
        }

        .email-wrapper {
            background-color: #F4F4F0;
            padding: 40px 16px;
        }

        .email-card {
            max-width: 580px;
            margin: 0 auto;
            background-color: #FFFFFF;
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid #E8E8E4;
        }

        .accent-bar {
            height: 4px;
            background-color: #FFCB3D;
        }

        .header {
            padding: 32px 40px 28px;
            border-bottom: 1px solid #EBEBEB;
        }

        .body {
            padding: 36px 40px;
        }

        .footer {
            padding: 24px 40px;
            background-color: #FAFAFA;
            border-top: 1px solid #EBEBEB;
        }

        h1 {
            font-family: 'Plus Jakarta Sans', Arial, sans-serif;
            font-size: 22px;
            font-weight: 700;
            color: #111111;
            margin: 0 0 8px;
            line-height: 1.3;
        }

        p {
            font-family: 'Plus Jakarta Sans', Arial, sans-serif;
            font-size: 15px;
            color: #444444;
            line-height: 1.65;
            margin: 0 0 16px;
        }

        .label {
            font-family: 'Plus Jakarta Sans', Arial, sans-serif;
            font-size: 11px;
            font-weight: 600;
            color: #888888;
            text-transform: uppercase;
            letter-spacing: 0.6px;
        }

        .value {
            font-family: 'Plus Jakarta Sans', Arial, sans-serif;
            font-size: 14px;
            color: #111111;
            font-weight: 500;
        }

        .detail-row td {
            padding: 9px 0;
            border-bottom: 1px solid #F0F0F0;
        }

        .detail-row:last-child td {
            border-bottom: none;
        }

        .btn a {
            font-family: 'Plus Jakarta Sans', Arial, sans-serif;
            font-size: 14px;
            font-weight: 700;
            color: #111111 !important;
            text-decoration: none;
        }

        .notice {
            background-color: #FFFBEB;
            border-left: 3px solid #F0B429;
            border-radius: 0 6px 6px 0;
            padding: 12px 16px;
            font-size: 13px;
            color: #444444;
            font-family: 'Plus Jakarta Sans', Arial, sans-serif;
        }

        .footer p {
            font-size: 12px;
            color: #999999;
            margin: 0 0 4px;
        }

        .footer a {
            color: #666666;
            text-decoration: underline;
        }

        @media only screen and (max-width: 600px) {
            .email-wrapper {
                padding: 0 !important;
            }

            .email-card {
                border-radius: 0 !important;
                border-left: none !important;
                border-right: none !important;
            }

            .header, .body, .footer {
                padding-left: 24px !important;
                padding-right: 24px !important;
            }
        }
    </style>
</head>
<body>

<div class="email-wrapper">
    <table class="email-card" width="580" cellpadding="0" cellspacing="0" border="0"
           align="center" style="max-width:580px;width:100%;background:#fff;
         border-radius:12px;border:1px solid #E8E8E4;overflow:hidden;">

        <!-- Accent bar -->
        <tr>
            <td style="height:4px;background-color:{% block accent_color %}#FFCB3D{% endblock %};font-size:0;line-height:0;">
                &nbsp;
            </td>
        </tr>

        <!-- Header with logo -->
        <tr>
            <td class="header" style="padding:28px 40px 24px;border-bottom:1px solid #EBEBEB;">
                <img {% raw %}src="{{ logo_url }}"{% endraw %}
                     alt="{{ project_name }}"
                     width="120"
                     style="display:block;height:auto;border:0;max-width:120px;"
                     onerror="this.style.display='none'">
            </td>
        </tr>

        <!-- Body -->
        <tr>
            <td class="body" style="padding:36px 40px;">
                {% raw %}{% block content %}{% endblock %}{% endraw %}
            </td>
        </tr>

        <!-- Footer -->
        <tr>
            <td class="footer" style="padding:20px 40px 24px;background-color:#FAFAFA;
          border-top:1px solid #EBEBEB;">
                {% raw %}
                {% block footer %}
                    <p style="font-family:'Plus Jakarta Sans',Arial,sans-serif;font-size:12px;
                   color:#999999;margin:0 0 4px;line-height:1.5;">
                        Hai bisogno di aiuto?
                        <a href="mailto:{{ support_email }}"
                           style="color:#666666;text-decoration:underline;">Contattaci</a>
                    </p>
                    <p style="font-family:'Plus Jakarta Sans',Arial,sans-serif;font-size:12px;
                   color:#BBBBBB;margin:0;line-height:1.5;">
                        &copy; {{ site_name }} &mdash; Tutti i diritti riservati.
                    </p>
                {% endblock %}
                {% endraw %}
            </td>
        </tr>

    </table>
</div>
</body>
</html>
