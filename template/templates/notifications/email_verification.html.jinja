{% raw %}{% extends "notifications/base_email.html" %}
{% block title %}Verifica il tuo indirizzo email — {% endraw %}{{ project_name }}{% raw %}{% endblock %}

{% block content %}
    <h1 style="font-family:'Plus Jakarta Sans',Arial,sans-serif;font-size:22px;
            font-weight:700;color:#111111;margin:0 0 8px;line-height:1.3;">
        Verifica il tuo indirizzo email
    </h1>
    <p style="font-family:'Plus Jakarta Sans',Arial,sans-serif;font-size:15px;
           color:#444444;line-height:1.65;margin:0 0 28px;">
        Ciao <strong style="color:#111111;">{{ user_name }}</strong>,
        clicca il pulsante qui sotto per confermare il tuo indirizzo email e attivare il tuo account.
    </p>

    <table cellpadding="0" cellspacing="0" border="0" style="margin-bottom:20px;">
        <tr>
            <td style="background-color:#FFCB3D;border-radius:8px;">
                <a href="{{ verify_url }}"
                   style="display:inline-block;padding:13px 24px;
                font-family:'Plus Jakarta Sans',Arial,sans-serif;
                font-size:14px;font-weight:700;color:#111111;text-decoration:none;">
                    Verifica email &rarr;
                </a>
            </td>
        </tr>
    </table>

    <p style="font-family:'Plus Jakarta Sans',Arial,sans-serif;font-size:13px;
           color:#999999;line-height:1.5;margin:0;">
        Se non hai creato un account su{% endraw %} {{ project_name }}, {% raw %}ignora questa email.
    </p>
{% endblock %}
{% endraw %}