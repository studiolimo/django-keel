name: CI

on:
  push:
    branches: [ development, production ]
  pull_request:
    branches: [ main, development, production ]

permissions:
  contents: read
  packages: write

jobs:
  lint:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Install uv
        uses: astral-sh/setup-uv@v6
        with:
          enable-cache: true

      - name: Set up Python
        run: uv python install {{ python_version }}

      - name: Install dependencies
        run: uv sync

      - name: Lint with ruff
        run: uv run ruff check .

      - name: Check formatting
        run: uv run ruff format --check .

      - name: Type check with mypy
        run: uv run mypy .


  test:
    runs-on: ubuntu-latest

    services:
      postgres:
        image: postgres:16-alpine
        env:
          POSTGRES_PASSWORD: postgres
          POSTGRES_DB: test_db
        options: >-
          --health-cmd pg_isready
          --health-interval 10s
          --health-timeout 5s
          --health-retries 5
        ports:
          - 5432:5432

      redis:
        image: redis:7-alpine
        options: >-
          --health-cmd "redis-cli ping"
          --health-interval 10s
          --health-timeout 5s
          --health-retries 5
        ports:
          - 6379:6379

    steps:
      - uses: actions/checkout@v4

      - name: Install uv
        uses: astral-sh/setup-uv@v6
        with:
          enable-cache: true

      - name: Set up Python
        run: uv python install {{ python_version }}

      - name: Install dependencies
        run: uv sync

      - name: Check for missing migrations
        env:
          DJANGO_SETTINGS_MODULE: config.settings.test
          DATABASE_URL: postgres://postgres:postgres@localhost:5432/test_db
          REDIS_URL: redis://localhost:6379/0
        run: uv run python manage.py makemigrations --check --dry-run

      - name: Run tests
        env:
          DATABASE_URL: postgres://postgres:postgres@localhost:5432/test_db
          REDIS_URL: redis://localhost:6379/0
        run: uv run pytest --cov --cov-report=xml

      - name: Upload coverage
        uses: codecov/codecov-action@v4
        with:
          files: ./coverage.xml
          fail_ci_if_error: false


  deploy-dev:
    name: Deploy Dev (be-dev.{{ project_domain_url }})
    runs-on: ubuntu-latest
    needs: [ lint, test ]
    if: github.ref == 'refs/heads/development' && github.event_name == 'push'
    environment:
      name: development
      url: https://be-dev.{{ project_domain_url }}
    steps:
      - uses: actions/checkout@v4

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: Login to GHCR
        uses: docker/login-action@v3
        with:
          registry: ghcr.io
          username: {% raw %}${{ github.actor }}{% endraw %}
          password: {% raw %}${{ secrets.GITHUB_TOKEN }}{% endraw %}

      - name: Build and push :dev image
        uses: docker/build-push-action@v6
        with:
          context: .
          push: true
          tags: ghcr.io/{{ git_repository_org_name }}/{{ git_repository_project_slug }}:dev
          cache-from: type=gha
          cache-to: type=gha,mode=max

      - name: Deploy to VPS
        uses: appleboy/ssh-action@v1
        with:
          host: {% raw %}${{ secrets.VPS_HOST }}{% endraw %}
          username: {% raw %}${{ secrets.VPS_USER }}{% endraw %}
          key: {% raw %}${{ secrets.VPS_SSH_KEY }}{% endraw %}
          port: {% raw %}${{ secrets.VPS_SSH_PORT }}{% endraw %}
          script: |
            echo "{% raw %}${{ secrets.GITHUB_TOKEN }}{% endraw %}" | docker login ghcr.io -u "{% raw %}${{ github.actor }}{% endraw %}" --password-stdin
            cd /home/django/{{ git_repository_project_slug }}
            docker compose -f deploy/compose/docker-compose.dev.yml --env-file deploy/compose/.env.dev pull backend celery celerybeat
            docker compose -f deploy/compose/docker-compose.dev.yml --env-file deploy/compose/.env.dev up -d backend celery celerybeat
            docker logout ghcr.io

  deploy-prod:
    name: Deploy Prod (be.{{ project_domain_url }})
    runs-on: ubuntu-latest
    needs: [ lint, test ]
    if: github.ref == 'refs/heads/production' && github.event_name == 'push'
    environment:
      name: production
      url: https://be.{{ project_domain_url }}
    steps:
      - uses: actions/checkout@v4

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: Login to GHCR
        uses: docker/login-action@v3
        with:
          registry: ghcr.io
          username: {% raw %}${{ github.actor }}{% endraw %}
          password: {% raw %}${{ secrets.GITHUB_TOKEN }}{% endraw %}

      - name: Build and push :latest image
        uses: docker/build-push-action@v6
        with:
          context: .
          push: true
          tags: ghcr.io/{{ git_repository_org_name }}/{{ git_repository_project_slug }}:latest
          cache-from: type=gha
          cache-to: type=gha,mode=max

      - name: Deploy to VPS
        uses: appleboy/ssh-action@v1
        with:
          host: {% raw %}${{ secrets.VPS_HOST }}{% endraw %}
          username: {% raw %}${{ secrets.VPS_USER }}{% endraw %}
          key: {% raw %}${{ secrets.VPS_SSH_KEY }}{% endraw %}
          port: {% raw %}${{ secrets.VPS_SSH_PORT }}{% endraw %}
          script: |
            echo "{% raw %}${{ secrets.GITHUB_TOKEN }}{% endraw %}" | docker login ghcr.io -u "{% raw %}${{ github.actor }}{% endraw %}" --password-stdin
            cd /home/django/{{ git_repository_project_slug }}
            docker compose -f deploy/compose/docker-compose.prod.yml --env-file deploy/compose/.env.prod pull backend celery celerybeat
            docker compose -f deploy/compose/docker-compose.prod.yml --env-file deploy/compose/.env.prod up -d backend celery celerybeat
            docker logout ghcr.io
