# Template per lo sviluppo locale (uv run).
# Copialo in `.env` e compila i valori: `cp .env.example .env`
# I file di deploy stanno invece in deploy/compose/ (.env.dev.example, .env.prod.example).

# Django Settings
DJANGO_SECRET_KEY=changeme
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_ALLOWED_HOSTS=http://localhost:9000,http://127.0.0.1:9000,capacitor://localhost

# CORS Settings
CORS_ALLOWED_ORIGIN_REGEXES=https://.*\.ngrok-free\.app
CORS_ALLOWED_ORIGINS=http://localhost:9000,http://127.0.0.1:9000,capacitor://localhost
CSRF_TRUSTED_ORIGINS=http://localhost:9000,http://127.0.0.1:9000,capacitor://localhost,https://*.ngrok-free.app

# Database
# PostgreSQL
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql://{{ project_slug }}_user:{{ project_slug }}_password@localhost:8432/{{ project_slug }}_db

# Password Reset
# ------------------------------------------------------------------------------
PASSWORD_RESET_TIMEOUT=3600
FRONTEND_URL=http://localhost:9000

# STRIPE
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
