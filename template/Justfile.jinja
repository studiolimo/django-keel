# Justfile for {{ project_name }} Backend

# List all available commands
default:
    @just --list

# Development server
dev:
    uv run python manage.py runserver

# Run tests
test:
    uv run pytest

# Format code
format:
    uv run ruff format .

# Lint code
lint:
    uv run ruff check .

# Type check
typecheck:
    uv run mypy .

# Run all quality checks
check: lint typecheck test

# Django shell
shell:
    uv run python manage.py shell_plus

# Make migrations
makemigrations:
    uv run python manage.py makemigrations

# Run migrations
migrate:
    uv run python manage.py migrate

# Create superuser
createsuperuser:
    uv run python manage.py createsuperuser

# Serve documentation
docs-serve:
    uv run mkdocs serve -a localhost:8001

# Build documentation
docs-build:
    uv run mkdocs build

# Install dependencies + git hooks (pre-commit: ruff, mypy, ...)
install:
    uv sync --all-extras
    uv run pre-commit install

# Update dependencies
update:
    uv lock --upgrade


# ─── VPS Commands (run from ~/projects/{{ git_repository_project_slug }} on the VPS, user 'admin') ───

DEV := "docker compose -f deploy/compose/docker-compose.dev.yml --env-file deploy/compose/.env.dev"
PROD := "docker compose -f deploy/compose/docker-compose.prod.yml --env-file deploy/compose/.env.prod"

{% raw %}# Show status of dev stack
dev-ps:
    {{DEV}} ps

# Show dev backend logs (follow)
dev-logs:
    {{DEV}} logs backend -f

# Restart dev backend
dev-restart:
    {{DEV}} restart backend

# Open Django shell on dev
dev-shell:
    {{DEV}} exec backend uv run python manage.py shell_plus

# Create superuser on dev
dev-createsuperuser:
    {{DEV}} exec backend uv run python manage.py createsuperuser

# Run migrations on dev
dev-migrate:
    {{DEV}} exec backend uv run python manage.py migrate

# Show status of prod stack
prod-ps:
    {{PROD}} ps

# Show prod backend logs (follow)
prod-logs:
    {{PROD}} logs backend -f

# Restart prod backend
prod-restart:
    {{PROD}} restart backend

# Create superuser on prod
prod-createsuperuser:
    {{PROD}} exec backend uv run python manage.py createsuperuser

# Run migrations on prod
prod-migrate:
    {{PROD}} exec backend uv run python manage.py migrate{% endraw %}
